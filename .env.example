# =====================================================
# Bye Henry Dashboard — Variables de entorno
# Copiar este archivo como .env.local para desarrollo
# Configurar todas estas variables en Vercel para producción
# =====================================================

# -----------------------------------------------
# AUTENTICACIÓN (NextAuth)
# -----------------------------------------------
# Usuario y contraseña de acceso al dashboard
ADMIN_USER=admin
ADMIN_PASSWORD=tu_contraseña_segura_aqui

# Secreto para firmar los tokens JWT de NextAuth
# Generá uno con: openssl rand -base64 32
NEXTAUTH_SECRET=tu_secreto_jwt_aqui_muy_largo_y_aleatorio

# URL base de la aplicación (cambiar en producción)
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------
# GOOGLE SHEETS API — SOLO LECTURA
# -----------------------------------------------
# Email de la Service Account de Google Cloud
# (se ve en la consola de Google Cloud > IAM > Service Accounts)
GOOGLE_SHEETS_CLIENT_EMAIL=dashboard@tu-proyecto.iam.gserviceaccount.com

# Clave privada de la Service Account
# Copiá el contenido del campo "private_key" del JSON descargado
# IMPORTANTE: Reemplazá los saltos de línea por \n literal
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAK...\n-----END RSA PRIVATE KEY-----\n"

# -----------------------------------------------
# IDs DE LAS PLANILLAS GOOGLE SHEETS
# -----------------------------------------------
# El ID está en la URL de la planilla:
# https://docs.google.com/spreadsheets/d/[ESTE_ES_EL_ID]/edit
#
# Planilla "Admin 2026 Henry" (hojas: Egresos, Impagas)
SHEET_ID_ADMIN=1AbCdEfGhIjKlMnOpQrStUvWxYz

# Planilla "Analisis y Base de datos APP Bye Henry" (hoja: EERR )
SHEET_ID_EERR=2XyZaBcDeFgHiJkLmNoPqRsTuVwX
